{
  "tag": "page",
  "title": "basic.html",
  "href": "about:blank",
  "children": [
    {
      "tag": "form",
      "selector": "form#login",
      "visible": true,
      "id": "login",
      "aria-label": "Login",
      "children": [
        {
          "tag": "label",
          "selector": "form > label:nth-of-type(1)",
          "visible": true,
          "for": "email",
          "text": "Email"
        },
        {
          "tag": "input",
          "selector": "input[name=\"email\"]",
          "visible": true,
          "name": "email",
          "type": "email",
          "placeholder": "Email"
        },
        {
          "tag": "label",
          "selector": "form > label:nth-of-type(2)",
          "visible": true,
          "for": "password",
          "text": "Password"
        },
        {
          "tag": "input",
          "selector": "input[name=\"password\"]",
          "visible": true,
          "name": "password",
          "type": "password"
        },
        {
          "tag": "button",
          "selector": "button[type=\"submit\"]",
          "visible": true,
          "type": "submit",
          "text": "Login"
        }
      ]
    }
  ]
}